# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aitcoin

# Session
SESSION_SECRET=change-this-to-a-long-random-secret

# AITCOIN Node RPC (optional — omit to run in simulation mode)
AITCOIN_RPC_URL=http://localhost:8332
AITCOIN_RPC_USER=aitcoinrpc
AITCOIN_RPC_PASS=your_rpc_password

# AI Life Layer
AI_POLL_INTERVAL_MS=30000
