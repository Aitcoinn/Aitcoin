# ============================================================
# AITCOIN AI Layer — Environment Variables
# Salin: cp .env.example .env
# ============================================================

# ── SERVER ────────────────────────────────────────────────────
PORT=3000

# ── DATABASE (opsional — wallet bisa jalan tanpa DB) ─────────
DATABASE_URL=postgresql://aitcoin:PASSWORD@localhost:5432/aitcoin_db

# ── NODE IDENTITY ─────────────────────────────────────────────
NODE_TYPE=AI_NODE
NODE_ID=node_main_001
P2P_PORT=9080
INITIAL_PEERS=

# ── AITCOIN C++ NODE RPC (opsional — untuk blockchain query) ─
AITCOIN_RPC_URL=http://127.0.0.1:8332
AITCOIN_RPC_USER=rpcuser
AITCOIN_RPC_PASS=YOUR_RPC_PASSWORD

# ── SECURITY ──────────────────────────────────────────────────
SESSION_SECRET=GANTI_DENGAN_STRING_ACAK_PANJANG
ALLOWED_ORIGINS=https://your-domain.com

# ── WALLET ────────────────────────────────────────────────────
DEV_WALLET_ADDRESS=AM4YaFDSPyLDkNEhSoeQk5QBvo9FuKdFk5
WALLET_STATE_DIR=./wallet_state

# ── NODE STATE & BACKUP ───────────────────────────────────────
NODE_STATE_DIR=./node_state
BACKUP_DIR=./backups

# ── AI CONFIG ─────────────────────────────────────────────────
AI_POLL_INTERVAL_MS=30000

# ── DESENTRALISASI PENUH ───────────────────────────────────────
# BOOTSTRAP_NODES — node awal untuk PEX (auto-discovery)
# Format: ws://ip:port,ws://ip2:port2
# Setelah terhubung ke 1 node, otomatis temukan semua node lain
BOOTSTRAP_NODES=ws://seed1.aitcoin.io:9080,ws://seed2.aitcoin.io:9080

# Opsional — override auto-generated node ID dari keypair
# NODE_ID diambil dari node_state/node_keypair.json secara otomatis
