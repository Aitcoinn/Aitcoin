{
  "name": "workspace",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.mjs",
    "wallet": "tsx src/wallet_cli.ts",
    "wallet:init": "tsx src/wallet_cli.ts init",
    "wallet:status": "tsx src/wallet_cli.ts status",
    "wallet:schedule": "tsx src/wallet_cli.ts schedule",
    "wallet:claim:free": "tsx src/wallet_cli.ts claim:free",
    "wallet:claim:vesting": "tsx src/wallet_cli.ts claim:vesting"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "@types/ws": "^8.5.10",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "esbuild": "^0.20.0",
    "esbuild-plugin-pino": "^2.1.0",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "bip39": "^3.1.0",
    "ws": "^8.17.0",
    "express": "^4.18.3",
    "pino": "^8.21.0",
    "pino-pretty": "^11.0.0",
    "drizzle-orm": "^0.38.0",
    "pg": "^8.20.0",
    "@noble/post-quantum": "^0.2.0",
    "@noble/hashes": "^1.4.0"
  }
}